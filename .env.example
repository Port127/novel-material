# PostgreSQL
DB_USER=admin
DB_PASSWORD=your_password
DB_NAME=novel_material
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@localhost:5432/${DB_NAME}

# pgAdmin
PGADMIN_EMAIL=admin@novel.internal
PGADMIN_PASSWORD=your_pgadmin_password

# Embedding 模型
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=qwen3-embedding
EMBEDDING_DIMENSION=4096
EMBEDDING_BASE_URL=http://localhost:11434
# EMBEDDING_API_KEY=

# LLM API Key（敏感信息，不入库）
# 对应 config/providers.yaml 中的 api_key_env
LLM_API_KEY_ALIYUN=your_aliyun_api_key
# LLM_API_KEY_DEEPSEEK=your_deepseek_api_key
# LLM_API_KEY_OPENAI=your_openai_api_key

# 默认 API Key（providers.yaml 不存在或不指定 --provider 时使用）
LLM_API_KEY=your_api_key

# 日志
LOG_LEVEL=INFO
LOG_DIR=logs

# 其他配置已迁移至 config/settings.yaml（受版本控制）
# LLM 参数、路径配置等请修改 settings.yaml
# 环境变量仍可作为覆盖手段（如 LLM_MAX_TOKENS=8000）
