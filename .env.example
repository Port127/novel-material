# PostgreSQL 配置
DB_USER=admin
DB_PASSWORD=your_password
DB_NAME=novel_material
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@localhost:5432/${DB_NAME}

# pgAdmin 配置
PGADMIN_EMAIL=admin@novel.internal
PGADMIN_PASSWORD=your_pgadmin_password

# Embedding 模型
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=qwen3-embedding
EMBEDDING_DIMENSION=4096
EMBEDDING_BASE_URL=http://localhost:11434

# LLM 配置（用于章级分析）
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=your_api_key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.3
LLM_RATE_LIMIT_SECONDS=10
# 章级分析批量大小：每次 API 调用处理多少章（默认 30，输出约 4500 tokens/批）
# 小模型（4K 上下文）设为 1，大模型（1M 上下文）可按输出上限调高
LLM_CHAPTER_BATCH_SIZE=30

# 路径配置
NOVELS_DIR=data/novels
GLOBAL_INDEX=data/index.yaml
TAGS_FILE=data/tags.yaml
