# PostgreSQL 配置
DATABASE_URL=postgresql://user:password@localhost:5432/novel_material
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Embedding 模型
EMBEDDING_PROVIDER=openai
# openai / bge / local
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1024
EMBEDDING_API_KEY=sk-xxx
EMBEDDING_BASE_URL=https://api.openai.com/v1

# LLM 配置（用于章级分析）
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.openai.com/v1
LLM_RATE_LIMIT_SECONDS=1

# 路径配置
NOVELS_DIR=data/novels
GLOBAL_INDEX=data/index.yaml
TAGS_FILE=data/tags.yaml
